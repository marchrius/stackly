DATABASE_URL="postgresql://stackly:stackly@localhost:5432/stackly"
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
UPLOAD_DIR="./public/uploads"
NODE_ENV="development"

# OIDC (generic + provider presets)
OIDC_ENABLED="false"
OIDC_PROVIDER="generic" # generic | keycloak | microsoft | google
OIDC_ISSUER_URL=""      # required for generic/keycloak, optional override for microsoft/google
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_SCOPES="openid profile email"

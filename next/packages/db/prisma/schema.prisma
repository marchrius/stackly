// prisma/schema.prisma
// Rispecchia il database PostgreSQL di Stackly (tabelle stk_*)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid()) @db.Char(36)
  username            String    @unique @db.VarChar(32)
  email               String    @unique
  password            String
  enabled             Boolean   @default(true)
  primaryAuthMethod   String    @default("credentials") @map("primary_auth_method") @db.VarChar(20)
  roles               Json      @default("[\"ROLE_USER\"]")
  currency            String    @default("EUR") @db.VarChar(3)
  locale              String    @default("en") @db.VarChar(5)
  timezone            String?   @db.VarChar(50)
  dateFormat          String    @default("Y-m-d") @db.VarChar(10)
  diskSpaceAllowed    BigInt    @default(536870912)
  diskSpaceUsed       BigInt    @default(0)
  theme                           String    @default("auto") @db.VarChar(10)
  displayMode                     String    @default("grid") @db.VarChar(4)
  wishlistDisplayMode             String    @default("grid") @db.VarChar(4)
  albumDisplayMode                String    @default("grid") @db.VarChar(4)
  visibility                      String    @default("public") @db.VarChar(10)
  avatar                          String?   @unique
  createdAt                       DateTime  @default(now()) @map("created_at")
  updatedAt                       DateTime? @updatedAt @map("updated_at")
  collectionsDisplayConfiguration DisplayConfiguration? @relation("UserCollectionsDisplayConfiguration", fields: [collectionsDisplayConfigurationId], references: [id])
  collectionsDisplayConfigurationId String? @unique @db.Char(36) @map("collections_display_configuration_id")

  collections           Collection[]
  albums                Album[]
  wishlists             Wishlist[]
  tags                  Tag[]
  tagCategories         TagCategory[]
  templates             Template[]
  choiceLists           ChoiceList[]
  inventories           Inventory[]
  loans                 Loan[]
  logs                  Log[]
  scrapers              Scraper[]
  searches              Search[]
  items                 Item[]
  photos                Photo[]
  wishes                Wish[]
  paths                 Path[]
  displayConfigurations DisplayConfiguration[]
  fields                Field[]
  oauthProviders        OAuthProvider[]

  @@map("stk_user")
}

model OAuthProvider {
  id                String    @id @default(uuid()) @db.Char(36)
  userId            String    @db.Char(36) @map("user_id")
  issuer            String    @db.VarChar(255)
  providerName      String    @map("provider_name") @db.VarChar(50)
  subject           String    @db.VarChar(255)
  email             String?   @db.VarChar(255)
  displayName       String?   @map("display_name") @db.VarChar(255)
  picture           String?   @db.Text
  accessTokenExpiry DateTime? @map("access_token_expiry")
  refreshToken      String?   @map("refresh_token") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([issuer, subject])
  @@unique([userId, providerName])
  @@index([userId], name: "idx_oauth_provider_user")
  @@index([issuer, subject], name: "idx_oauth_provider_issuer_subject")
  @@map("stk_oauth_provider")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONFIGURATION
// ─────────────────────────────────────────────────────────────────────────────

model Configuration {
  id        String   @id @default(uuid()) @db.Char(36)
  label     String   @unique
  value     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("stk_configuration")
}

// ─────────────────────────────────────────────────────────────────────────────
// COLLECTION
// ─────────────────────────────────────────────────────────────────────────────

model Collection {
  id               String    @id @default(uuid()) @db.Char(36)
  title            String
  color            String?   @db.VarChar(7)
  image            String?   @unique
  scrapedFromUrl   String?   @db.Text @map("scraped_from_url")
  visibility       String    @default("public") @db.VarChar(10)
  parentVisibility String    @default("public") @db.VarChar(10) @map("parent_visibility")
  finalVisibility  String    @default("public") @db.VarChar(10) @map("final_visibility")
  seenCounter      Int       @default(0) @map("seen_counter")
  childrenCount    Int       @default(0) @map("children_count")
  cachedValues     Json?     @map("cached_values")

  owner                    User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId                  String?     @db.Char(36) @map("owner_id")
  parent                   Collection? @relation("CollectionChildren", fields: [parentId], references: [id], onDelete: SetNull)
  parentId                 String?     @db.Char(36) @map("parent_id")
  itemsDefaultTemplate     Template?   @relation("CollectionDefaultTemplate", fields: [itemsDefaultTemplateId], references: [id], onDelete: SetNull)
  itemsDefaultTemplateId   String?     @db.Char(36) @map("items_default_template_id")
  childrenDisplayConfig    DisplayConfiguration? @relation("CollectionChildrenDisplay", fields: [childrenDisplayConfigId], references: [id])
  childrenDisplayConfigId  String?     @unique @db.Char(36) @map("children_display_config_id")
  itemsDisplayConfig       DisplayConfiguration? @relation("CollectionItemsDisplay", fields: [itemsDisplayConfigId], references: [id])
  itemsDisplayConfigId     String?     @unique @db.Char(36) @map("items_display_config_id")

  children Collection[] @relation("CollectionChildren")
  items    Item[]
  data     Datum[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([finalVisibility], name: "idx_collection_final_visibility")
  @@index([ownerId], name: "idx_collection_owner")
  @@map("stk_collection")
}

// ─────────────────────────────────────────────────────────────────────────────
// ITEM
// ─────────────────────────────────────────────────────────────────────────────

model Item {
  id                  String    @id @default(uuid()) @db.Char(36)
  name                String
  quantity            Int       @default(1)
  visibility          String    @default("public") @db.VarChar(10)
  parentVisibility    String    @default("public") @db.VarChar(10) @map("parent_visibility")
  finalVisibility     String    @default("public") @db.VarChar(10) @map("final_visibility")
  scrapedFromUrl      String?   @db.Text @map("scraped_from_url")
  image               String?   @unique
  imageSmallThumbnail String?   @unique @map("image_small_thumbnail")
  imageLargeThumbnail String?   @unique @map("image_large_thumbnail")
  seenCounter         Int       @default(0) @map("seen_counter")
  cachedValues        Json?     @map("cached_values")

  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  collectionId String?     @db.Char(36) @map("collection_id")
  owner        User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId      String?     @db.Char(36) @map("owner_id")

  data         Datum[]
  loans        Loan[]
  tags         Tag[]    @relation("ItemTags")
  relatedItems Item[]   @relation("RelatedItems")
  relatedTo    Item[]   @relation("RelatedItems")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([finalVisibility], name: "idx_item_final_visibility")
  @@index([collectionId], name: "idx_item_collection")
  @@index([ownerId], name: "idx_item_owner")
  @@map("stk_item")
}

// ─────────────────────────────────────────────────────────────────────────────
// DATUM
// ─────────────────────────────────────────────────────────────────────────────

model Datum {
  id                  String    @id @default(uuid()) @db.Char(36)
  type                String    @db.VarChar(15)
  label               String?
  value               String?   @db.Text
  position            Int?
  currency            String?   @db.VarChar(3)
  image               String?   @unique
  imageSmallThumbnail String?   @unique @map("image_small_thumbnail")
  file                String?   @unique
  video               String?   @unique
  originalFilename    String?   @map("original_filename")
  visibility          String    @default("public") @db.VarChar(10)
  parentVisibility    String    @default("public") @db.VarChar(10) @map("parent_visibility")
  finalVisibility     String    @default("public") @db.VarChar(10) @map("final_visibility")

  item         Item?       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId       String?     @db.Char(36) @map("item_id")
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String?     @db.Char(36) @map("collection_id")
  choiceList   ChoiceList? @relation(fields: [choiceListId], references: [id], onDelete: SetNull)
  choiceListId String?     @db.Char(36) @map("choice_list_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([label], name: "idx_datum_label")
  @@index([finalVisibility], name: "idx_datum_final_visibility")
  @@index([itemId], name: "idx_datum_item")
  @@map("stk_datum")
}

// ─────────────────────────────────────────────────────────────────────────────
// ALBUM & PHOTO
// ─────────────────────────────────────────────────────────────────────────────

model Album {
  id               String    @id @default(uuid()) @db.Char(36)
  title            String
  color            String?   @db.VarChar(7)
  image            String?   @unique
  visibility       String    @default("public") @db.VarChar(10)
  parentVisibility String    @default("public") @db.VarChar(10) @map("parent_visibility")
  finalVisibility  String    @default("public") @db.VarChar(10) @map("final_visibility")
  seenCounter      Int       @default(0) @map("seen_counter")
  childrenCount    Int       @default(0) @map("children_count")
  photosCount      Int       @default(0) @map("photos_count")

  owner    User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId  String? @db.Char(36) @map("owner_id")
  parent   Album?  @relation("AlbumChildren", fields: [parentId], references: [id], onDelete: SetNull)
  parentId String? @db.Char(36) @map("parent_id")

  children Album[] @relation("AlbumChildren")
  photos   Photo[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([finalVisibility], name: "idx_album_final_visibility")
  @@index([ownerId], name: "idx_album_owner")
  @@map("stk_album")
}

model Photo {
  id                  String    @id @default(uuid()) @db.Char(36)
  title               String
  comment             String?   @db.Text
  place               String?
  image               String?   @unique
  imageSmallThumbnail String?   @unique @map("image_small_thumbnail")
  takenAt             DateTime? @map("taken_at")
  visibility          String    @default("public") @db.VarChar(10)
  parentVisibility    String    @default("public") @db.VarChar(10) @map("parent_visibility")
  finalVisibility     String    @default("public") @db.VarChar(10) @map("final_visibility")
  seenCounter         Int       @default(0) @map("seen_counter")

  album   Album?  @relation(fields: [albumId], references: [id], onDelete: SetNull)
  albumId String? @db.Char(36) @map("album_id")
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([finalVisibility], name: "idx_photo_final_visibility")
  @@index([albumId], name: "idx_photo_album")
  @@map("stk_photo")
}

// ─────────────────────────────────────────────────────────────────────────────
// WISHLIST & WISH
// ─────────────────────────────────────────────────────────────────────────────

model Wishlist {
  id               String    @id @default(uuid()) @db.Char(36)
  name             String
  color            String?   @db.VarChar(7)
  image            String?   @unique
  visibility       String    @default("public") @db.VarChar(10)
  parentVisibility String    @default("public") @db.VarChar(10) @map("parent_visibility")
  finalVisibility  String    @default("public") @db.VarChar(10) @map("final_visibility")
  seenCounter      Int       @default(0) @map("seen_counter")
  childrenCount    Int       @default(0) @map("children_count")
  wishesCount      Int       @default(0) @map("wishes_count")

  owner    User?      @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId  String?    @db.Char(36) @map("owner_id")
  parent   Wishlist?  @relation("WishlistChildren", fields: [parentId], references: [id], onDelete: SetNull)
  parentId String?    @db.Char(36) @map("parent_id")

  children Wishlist[] @relation("WishlistChildren")
  wishes   Wish[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([finalVisibility], name: "idx_wishlist_final_visibility")
  @@index([ownerId], name: "idx_wishlist_owner")
  @@map("stk_wishlist")
}

model Wish {
  id                  String    @id @default(uuid()) @db.Char(36)
  name                String
  url                 String?   @db.Text
  price               String?
  currency            String?   @db.VarChar(6)
  image               String?   @unique
  imageSmallThumbnail String?   @unique @map("image_small_thumbnail")
  comment             String?   @db.Text
  visibility          String    @default("public") @db.VarChar(10)
  parentVisibility    String    @default("public") @db.VarChar(10) @map("parent_visibility")
  finalVisibility     String    @default("public") @db.VarChar(10) @map("final_visibility")
  seenCounter         Int       @default(0) @map("seen_counter")

  wishlist   Wishlist? @relation(fields: [wishlistId], references: [id], onDelete: SetNull)
  wishlistId String?   @db.Char(36) @map("wishlist_id")
  owner      User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId    String?   @db.Char(36) @map("owner_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([finalVisibility], name: "idx_wish_final_visibility")
  @@index([wishlistId], name: "idx_wish_wishlist")
  @@map("stk_wish")
}

// ─────────────────────────────────────────────────────────────────────────────
// TAG & TAG CATEGORY
// ─────────────────────────────────────────────────────────────────────────────

model Tag {
  id                  String    @id @default(uuid()) @db.Char(36)
  label               String
  description         String?   @db.Text
  image               String?   @unique
  imageSmallThumbnail String?   @unique @map("image_small_thumbnail")
  visibility          String    @default("public") @db.VarChar(10)
  seenCounter         Int       @default(0) @map("seen_counter")

  owner      User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId    String?      @db.Char(36) @map("owner_id")
  category   TagCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?      @db.Char(36) @map("category_id")

  items Item[] @relation("ItemTags")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([visibility], name: "idx_tag_visibility")
  @@index([ownerId], name: "idx_tag_owner")
  @@map("stk_tag")
}

model TagCategory {
  id          String  @id @default(uuid()) @db.Char(36)
  label       String
  description String? @db.Text
  color       String? @db.VarChar(7)

  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  tags Tag[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([ownerId], name: "idx_tag_category_owner")
  @@map("stk_tag_category")
}

// ─────────────────────────────────────────────────────────────────────────────
// TEMPLATE & FIELD
// ─────────────────────────────────────────────────────────────────────────────

model Template {
  id   String @id @default(uuid()) @db.Char(36)
  name String

  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  fields      Field[]
  collections Collection[] @relation("CollectionDefaultTemplate")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([ownerId], name: "idx_template_owner")
  @@map("stk_template")
}

model Field {
  id         String  @id @default(uuid()) @db.Char(36)
  name       String
  position   Int
  type       String  @db.VarChar(15)
  visibility String  @default("public") @db.VarChar(10)

  template     Template?   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId   String?     @db.Char(36) @map("template_id")
  choiceList   ChoiceList? @relation(fields: [choiceListId], references: [id], onDelete: SetNull)
  choiceListId String?     @db.Char(36) @map("choice_list_id")
  owner        User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId      String?     @db.Char(36) @map("owner_id")

  @@index([templateId], name: "idx_field_template")
  @@map("stk_field")
}

// ─────────────────────────────────────────────────────────────────────────────
// CHOICE LIST
// ─────────────────────────────────────────────────────────────────────────────

model ChoiceList {
  id      String @id @default(uuid()) @db.Char(36)
  name    String @db.VarChar(255)
  choices Json   @default("[]")

  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  data   Datum[]
  fields Field[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([ownerId], name: "idx_choice_list_owner")
  @@map("stk_choice_list")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────────────────────────────────────

model Inventory {
  id      String @id @default(uuid()) @db.Char(36)
  name    String
  content Json   @default("[]")

  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([ownerId], name: "idx_inventory_owner")
  @@map("stk_inventory")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOAN
// ─────────────────────────────────────────────────────────────────────────────

model Loan {
  id         String    @id @default(uuid()) @db.Char(36)
  lentTo     String    @map("lent_to")
  lentAt     DateTime  @map("lent_at")
  returnedAt DateTime? @map("returned_at")

  item    Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemId  String? @db.Char(36) @map("item_id")
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  @@index([ownerId], name: "idx_loan_owner")
  @@map("stk_loan")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOG
// ─────────────────────────────────────────────────────────────────────────────

model Log {
  id            String    @id @default(uuid()) @db.Char(36)
  type          String?   @db.VarChar(6)
  loggedAt      DateTime? @map("logged_at")
  objectId      String    @db.VarChar(36) @map("object_id")
  objectLabel   String    @map("object_label")
  objectClass   String    @map("object_class")
  objectDeleted Boolean   @default(false) @map("object_deleted")

  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  @@index([ownerId], name: "idx_log_owner")
  @@index([loggedAt], name: "idx_log_logged_at")
  @@map("stk_log")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCRAPER & PATH
// ─────────────────────────────────────────────────────────────────────────────

model Scraper {
  id         String  @id @default(uuid()) @db.Char(36)
  name       String
  type       String? @db.VarChar(15)
  urlPattern String? @db.Text @map("url_pattern")
  namePath   String? @db.Text @map("name_path")
  imagePath  String? @db.Text @map("image_path")
  pricePath  String? @db.Text @map("price_path")
  headers    Json?   @default("[]")

  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  dataPaths Path[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([ownerId], name: "idx_scraper_owner")
  @@map("stk_scraper")
}

model Path {
  id       String @id @default(uuid()) @db.Char(36)
  name     String
  type     String @db.VarChar(15)
  path     String @db.Text
  position Int

  scraper   Scraper? @relation(fields: [scraperId], references: [id], onDelete: Cascade)
  scraperId String?  @db.Char(36) @map("scraper_id")
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId   String?  @db.Char(36) @map("owner_id")

  @@index([scraperId], name: "idx_path_scraper")
  @@map("stk_path")
}

// ─────────────────────────────────────────────────────────────────────────────
// SEARCH
// ─────────────────────────────────────────────────────────────────────────────

model Search {
  id              String @id @default(uuid()) @db.Char(36)
  name            String?
  numberOfResults BigInt? @map("number_of_results")

  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  displayConfiguration   DisplayConfiguration? @relation(fields: [displayConfigurationId], references: [id])
  displayConfigurationId String?               @unique @db.Char(36) @map("display_configuration_id")

  blocks SearchBlock[]

  @@index([ownerId], name: "idx_search_owner")
  @@map("stk_search")
}

model SearchBlock {
  id        String  @id @default(uuid()) @db.Char(36)
  condition String? @map("condition")

  search   Search? @relation(fields: [searchId], references: [id])
  searchId String? @db.Char(36) @map("search_id")

  filters SearchFilter[]

  @@index([searchId], name: "idx_search_block_search")
  @@map("stk_search_block")
}

model SearchFilter {
  id         String  @id @default(uuid()) @db.Char(36)
  condition  String? @map("condition")
  type       String
  datumLabel String? @map("datum_label")
  datumType  String? @map("datum_type")
  operator   String
  value      String?

  block   SearchBlock? @relation(fields: [blockId], references: [id])
  blockId String?      @db.Char(36) @map("block_id")

  @@index([blockId], name: "idx_search_filter_block")
  @@map("stk_search_filter")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISPLAY CONFIGURATION
// ─────────────────────────────────────────────────────────────────────────────

model DisplayConfiguration {
  id                   String  @id @default(uuid()) @db.Char(36)
  label                String?
  displayMode          String  @default("grid") @db.VarChar(4) @map("display_mode")
  sortingProperty      String? @db.VarChar(255) @map("sorting_property")
  sortingType          String? @db.VarChar(15) @map("sorting_type")
  sortingDirection     String? @db.VarChar(255) @map("sorting_direction")
  showVisibility       Boolean @default(true) @map("show_visibility")
  showActions          Boolean @default(true) @map("show_actions")
  showNumberOfChildren Boolean @default(true) @map("show_number_of_children")
  showNumberOfItems    Boolean @default(true) @map("show_number_of_items")
  showItemQuantities   Boolean @default(false) @map("show_item_quantities")
  columns              Json?   @default("[]")

  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String? @db.Char(36) @map("owner_id")

  userCollectionsIndex User? @relation("UserCollectionsDisplayConfiguration")
  collectionChildren Collection? @relation("CollectionChildrenDisplay")
  collectionItems    Collection? @relation("CollectionItemsDisplay")
  search             Search?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("stk_display_configuration")
}

{
  "name": "koillection",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "dotenv -e .env -- turbo run build",
    "dev": "dotenv -e .env -- turbo run dev",
    "lint": "dotenv -e .env -- turbo run lint",
    "type-check": "dotenv -e .env -- turbo run type-check",
    "i18n:validate": "python3 scripts/validate_i18n_messages.py",
    "db:generate": "dotenv -e .env -- turbo run db:generate --filter=@koillection/db",
    "db:push": "dotenv -e .env -- turbo run db:push --filter=@koillection/db",
    "db:migrate": "dotenv -e .env -- turbo run db:migrate --filter=@koillection/db",
    "db:studio": "dotenv -e .env -- turbo run db:studio --filter=@koillection/db"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7",
    "prettier": "^3.4.2",
    "eslint": "^9.18.0"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0"
  }
}


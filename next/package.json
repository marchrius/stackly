{
  "name": "koillection",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "turbo run db:generate --filter=@koillection/db",
    "db:push": "turbo run db:push --filter=@koillection/db",
    "db:migrate": "turbo run db:migrate --filter=@koillection/db",
    "db:studio": "turbo run db:studio --filter=@koillection/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7",
    "prettier": "^3.4.2",
    "eslint": "^9.18.0"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0"
  }
}


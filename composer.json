{
    "name": "benjaminjonard/koillection",
    "description": "Koillection is a self-hosted service allowing users to manage any kind of collection.",
    "type": "project",
    "license": "MIT",
    "version": "1.8.0",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "api-platform/core": "4.3.0",
        "composer/semver": "3.4.4",
        "doctrine/doctrine-bundle": "3.2.2",
        "doctrine/doctrine-migrations-bundle": "4.0.0",
        "doctrine/orm": "3.6.2",
        "doctrine/dbal": "4.4.2",
        "doctrine/persistence": "4.1.1",
        "lexik/jwt-authentication-bundle": "3.2.0",
        "maennchen/zipstream-php": "3.2.1",
        "nelmio/cors-bundle": "2.6.1",
        "symfony/asset": "8.0.6",
        "symfony/browser-kit": "8.0.4",
        "symfony/cache": "8.0.7",
        "symfony/console": "8.0.7",
        "symfony/css-selector": "8.0.6",
        "symfony/dependency-injection": "8.0.7",
        "symfony/dotenv": "8.0.7",
        "symfony/error-handler": "8.0.4",
        "symfony/event-dispatcher": "8.0.4",
        "symfony/expression-language": "8.0.4",
        "symfony/finder": "8.0.6",
        "symfony/flex": "2.10.0",
        "symfony/form": "8.0.7",
        "symfony/framework-bundle": "8.0.7",
        "symfony/http-client": "8.0.7",
        "symfony/http-foundation": "8.0.7",
        "symfony/http-kernel": "8.0.7",
        "symfony/intl": "8.0.6",
        "symfony/mime": "8.0.7",
        "symfony/monolog-bundle": "4.0.1",
        "symfony/process": "8.0.5",
        "symfony/property-access": "8.0.4",
        "symfony/property-info": "8.0.7",
        "symfony/routing": "8.0.6",
        "symfony/runtime": "8.0.1",
        "symfony/security-bundle": "8.0.6",
        "symfony/security-core": "8.0.4",
        "symfony/security-http": "8.0.6",
        "symfony/serializer": "8.0.7",
        "symfony/string": "8.0.6",
        "symfony/translation": "8.0.6",
        "symfony/twig-bridge": "8.0.7",
        "symfony/twig-bundle": "8.0.4",
        "symfony/uid": "8.0.4",
        "symfony/validator": "8.0.7",
        "symfony/web-link": "8.0.4",
        "symfony/webpack-encore-bundle": "2.4.0",
        "symfony/yaml": "8.0.6",
        "twig/extra-bundle": "3.23.0",
        "twig/intl-extra": "3.23.0",
        "twig/string-extra": "3.23.0",
        "symfony/panther": "^2.3",
        "twig/twig": "3.23.0"
    },
    "require-dev": {
        "brianium/paratest": "7.19.2",
        "dama/doctrine-test-bundle": "8.6.0",
        "friendsofphp/php-cs-fixer": "3.94.2",
        "justinrainbow/json-schema": "6.7.2",
        "phpunit/php-code-coverage": "12.5.3",
        "phpunit/phpunit": "12.5.14",
        "rector/rector": "2.3.9",
        "symfony/maker-bundle": "1.66.0",
        "symfony/stopwatch": "8.0.0",
        "symfony/var-dumper": "8.0.6",
        "symfony/web-profiler-bundle": "8.0.7",
        "zenstruck/foundry": "2.9.2"
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Api\\": "api/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test:coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "Composer\\Config::disableProcessTimeout",
            "./vendor/phpunit/phpunit/phpunit --color=always --coverage-html=\"output/code-coverage\""
        ],
        "test:phpunit": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/phpunit/phpunit/phpunit --display-deprecations"
        ],
        "test:paratest": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/paratest --runner=WrapperRunner"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "docker": false,
            "require": "8.0.*"
        },
        "runtime": {
            "class": "Runtime\\FrankenPhpSymfony\\Runtime",
            "dotenv_overload": true
        }
    }
}

{
  "name": "stackly",
  "version": "2.0.0-alpha-6",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "dotenv -e .env -- sh -c 'NODE_ENV=production turbo run build'",
    "dev": "dotenv -e .env -- turbo run dev db:studio",
    "lint": "dotenv -e .env -- turbo run lint",
    "maintenance:refresh-cached-values": "dotenv -e .env -- node scripts/refresh-cached-values.mjs",
    "maintenance:regenerate-logs": "dotenv -e .env -- node scripts/regenerate-logs.mjs",
    "maintenance:regenerate-thumbnails": "dotenv -e .env -- node scripts/regenerate-thumbnails.mjs",
    "start": "npm run start --workspace=@stackly/web",
    "test": "turbo run test",
    "type-check": "dotenv -e .env -- turbo run type-check",
    "i18n:validate": "node scripts/validate-i18n-messages.mjs",
    "legacy:migrate": "dotenv -e .env -- node scripts/legacy-migrate-db.mjs",
    "legacy:validate": "dotenv -e .env -- node scripts/legacy-validate-db.mjs",
    "legacy:uploads:audit": "dotenv -e .env -- node scripts/legacy-audit-uploads.mjs",
    "legacy:uploads:copy": "dotenv -e .env -- node scripts/legacy-copy-uploads.mjs",
    "db:generate": "dotenv -e .env -- turbo run db:generate --filter=@stackly/db",
    "db:push": "dotenv -e .env -- turbo run db:push --filter=@stackly/db",
    "db:migrate": "dotenv -e .env -- turbo run db:migrate --filter=@stackly/db",
    "db:studio": "dotenv -e .env -- turbo run db:studio --filter=@stackly/db",
    "db:seed": "dotenv -e .env -- npm run db:seed --workspace=@stackly/db",
    "db:seed:demo": "dotenv -e .env -- node scripts/seed-demo-data.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "turbo": "^2.9.18",
    "typescript": "^5.7.3"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
